{
  "description": "memory-system hooks: PreToolUse emits memory injection (project + global) for sessions that need it; PostToolUse confirms delivery so rejected tool calls don't burn the inject. Stop spawns a detached worker that asks Claude to audit the recent turn and persist anything memo-worthy via the memory-system skill.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/inject-memory.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/confirm-inject.mjs",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/audit-memory.mjs",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
